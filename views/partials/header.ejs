<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <title><%= title %></title>
  <meta name="description" content="<%= description %>" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/favicon-32.png" sizes="32x32" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

  <!-- Open Graph (link previews in texts / social media) -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:image" content="/images/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="J&M Serenity Spa" />

  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="J&amp;M Serenity Spa Home">
      <img src="/images/logo.png" alt="J&amp;M Serenity Spa" class="brand-logo" />
      <span class="brand-wordmark">
        <span class="brand-name">J&amp;M Serenity Spa</span>
        <span class="brand-tag">Signature Treatments</span>
      </span>
    </a>

    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false">☰</button>

    <nav class="nav" aria-label="Primary navigation">
      <a class="nav-link <%= activePage === 'home' ? 'is-active' : '' %>" href="/">Home</a>
      <a class="nav-link <%= activePage === 'treatments' ? 'is-active' : '' %>" href="/treatments">Treatments</a>
      <a class="nav-link <%= activePage === 'about' ? 'is-active' : '' %>" href="/about">About</a>
      <a class="nav-link <%= activePage === 'book' ? 'is-active' : '' %>" href="/book">Book</a>
      <a class="nav-link <%= activePage === 'gallery' ? 'is-active' : '' %>" href="/gallery">Gallery</a>
      <a class="nav-link <%= activePage === 'reviews' ? 'is-active' : '' %>" href="/reviews">Reviews</a>
      <a class="nav-link <%= activePage === 'memberships' ? 'is-active' : '' %>" href="/memberships">Memberships</a>
      <a class="nav-link <%= activePage === 'contact' ? 'is-active' : '' %>" href="/contact">Contact</a>
      <a class="nav-link <%= activePage === 'policies' ? 'is-active' : '' %>" href="/policies">Policies</a>

      <a class="btn btn-primary btn-small nav-cta" href="/book">Book Now</a>
    </nav>

    <a class="btn btn-primary btn-small header-cta" href="/book">Book Now</a>
  </div>
</header>