<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Gift Card Label — <%= cert.code %></title>
  <script src="/js/jsbarcode.min.js"></script>
  <style>
    /* Sized for 2" x 1" direct-thermal die-cut labels (Zebra GX420d). */
    @page { size: 2in 1in; margin: 0; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; }
    .toolbar { padding: 14px; background: #f2f2f2; text-align: center; border-bottom: 1px solid #ddd; }
    .toolbar button { font-size: 15px; padding: 8px 18px; cursor: pointer; }
    .toolbar .note { display: block; color: #666; font-size: 12px; margin-top: 6px; }
    .label {
      width: 2in; height: 1in; padding: 0.04in 0.06in;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      margin: 12px auto;
    }
    #bc { max-width: 100%; height: 0.42in; }
    .code { font-size: 8pt; letter-spacing: .5px; margin-top: 1px; }
    .amt { font-weight: 700; font-size: 15pt; margin-top: 2px; }
    @media print {
      .toolbar { display: none; }
      .label { margin: 0; }
    }
  </style>
</head>
<body>
  <div class="toolbar">
    <button onclick="window.print()">🖨 Print Label</button>
    <span class="note">2" × 1" label for the back of the gift card. (Once the Zebra is on the network, printing is one-click and skips this page.)</span>
  </div>

  <div class="label">
    <svg id="bc"></svg>
    <div class="code"><%= cert.code %></div>
    <div class="amt">$<%= (cert.amount || 0).toFixed(2) %></div>
  </div>

  <script>
    JsBarcode("#bc", "<%= cert.code %>", { format: "CODE128", displayValue: false, height: 40, margin: 0 });
  </script>
</body>
</html>
