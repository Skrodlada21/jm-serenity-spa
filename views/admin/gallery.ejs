<%- include('../partials/admin-header', { activePage: 'admin-gallery' }) %>

<main class="admin-main">
  <div class="container">
    <h1>Gallery Management</h1>

    <div class="card" style="margin-bottom: 1.5rem;">
      <h2>Upload Photo</h2>
      <form class="form" method="POST" action="/admin/gallery" enctype="multipart/form-data">
        <label>
          Image
          <input type="file" name="image" accept="image/*" required />
        </label>
        <div class="grid two">
          <label>
            Caption <span class="muted small">(optional)</span>
            <input type="text" name="caption" placeholder="e.g., Treatment Room 1" />
          </label>
          <label>
            Sort Order <span class="muted small">(lower = first)</span>
            <input type="number" name="sort_order" value="0" min="0" />
          </label>
        </div>
        <button class="btn btn-primary" type="submit">Upload</button>
      </form>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
      <% images.forEach(function(img) { %>
      <div class="card" style="padding: .5rem; text-align: center;">
        <img src="<%= img.filename %>" alt="<%= img.caption || 'Gallery' %>" style="width: 100%; height: 150px; object-fit: cover; border-radius: 10px;" />
        <p class="small muted" style="margin-top: .4rem;"><%= img.caption || 'No caption' %></p>
        <form method="POST" action="/admin/gallery/<%= img.id %>/delete" onsubmit="return confirm('Delete this image?')">
          <button class="btn btn-small btn-ghost" type="submit" style="color: #c0392b; margin-top: .3rem;">Delete</button>
        </form>
      </div>
      <% }); %>
      <% if (images.length === 0) { %>
      <p class="muted">No gallery images uploaded yet.</p>
      <% } %>
    </div>
  </div>
</main>

</body>
</html>
