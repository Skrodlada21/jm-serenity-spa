<%- include('../partials/admin-header', { activePage: 'admin-expenses' }) %>

<main class="admin-main">
  <div class="container">
    <h1>Expense Tracking</h1>

    <% function money(n){ return (Number(n)||0).toLocaleString('en-US',{minimumFractionDigits:2, maximumFractionDigits:2}); } %>
    <% var soonCutoff = new Date(Date.now()+7*24*60*60*1000).toISOString().slice(0,10); %>

    <!-- OUTSTANDING — WHAT'S DUE -->
    <% if (typeof outstanding !== 'undefined' && outstanding && outstanding.length > 0) { %>
    <div class="card" style="margin-bottom: 1.5rem; border-left: 5px solid #e74c3c;">
      <h2 style="font-size: 1.1rem; margin-bottom: .2rem;">💸 Outstanding — What's Due</h2>
      <p class="muted small" style="margin-bottom: .9rem;">Everything still owed, soonest due first. Click <strong>Record Payment</strong> to log an installment.</p>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr><th>Due Date</th><th>What / Who</th><th style="text-align:right;">Total</th><th style="text-align:right;">Paid</th><th style="text-align:right;">Remaining</th><th></th></tr>
          </thead>
          <tbody>
            <% outstanding.forEach(function(o) {
                 var overdue = o.due_date && o.due_date < today;
                 var soon = o.due_date && o.due_date >= today && o.due_date <= soonCutoff;
                 var pct = o.amount > 0 ? Math.min(100, Math.round((o.paid_to_date / o.amount) * 100)) : 0;
            %>
            <tr style="<%= overdue ? 'background:#fdecea;' : (soon ? 'background:#fff8f0;' : '') %>">
              <td style="white-space:nowrap;">
                <% if (o.due_date) { %>
                  <%= o.due_date %>
                  <% if (overdue) { %><br /><span style="font-size:.7rem; background:#e74c3c; color:#fff; padding:.1rem .4rem; border-radius:4px;">OVERDUE</span>
                  <% } else if (soon) { %><br /><span style="font-size:.7rem; background:#e67e22; color:#fff; padding:.1rem .4rem; border-radius:4px;">DUE SOON</span><% } %>
                <% } else { %><span class="muted small">no date</span><% } %>
              </td>
              <td>
                <strong><%= o.description %></strong>
                <% if (o.due_to) { %><br /><span style="font-size:.8rem; color:#e74c3c; font-weight:600;">Owe: <%= o.due_to %></span><% } %>
                <% if (o.auto_pay) { %> <span style="font-size:.7rem; background:#16a085; color:#fff; padding:.1rem .4rem; border-radius:4px;">🔄 Auto-Pay</span><% } %>
                <% if (o.paid_to_date > 0) { %>
                  <div style="height:6px; background:#eee; border-radius:3px; margin-top:.4rem; max-width:200px;"><div style="height:6px; width:<%= pct %>%; background:#27ae60; border-radius:3px;"></div></div>
                  <span class="muted small"><%= pct %>% paid</span>
                <% } %>
              </td>
              <td style="text-align:right; white-space:nowrap;">$<%= money(o.amount) %></td>
              <td style="text-align:right; white-space:nowrap; color:#27ae60;">$<%= money(o.paid_to_date) %></td>
              <td style="text-align:right; white-space:nowrap;"><strong style="color:#e74c3c;">$<%= money(o.remaining) %></strong></td>
              <td style="white-space:nowrap;">
                <button class="btn btn-small btn-primary" type="button" onclick="togglePay(<%= o.id %>)">Record Payment</button>
              </td>
            </tr>
            <tr id="pay-<%= o.id %>" style="display:none; background:#f4f9ff;">
              <td colspan="6">
                <form method="POST" action="/admin/expenses/<%= o.id %>/payment" class="form" style="display:flex; flex-wrap:wrap; gap:.6rem; align-items:flex-end; margin:0;">
                  <label style="margin:0;">Amount ($)<input type="number" name="amount" value="<%= o.remaining.toFixed(2) %>" min="0.01" step="0.01" required style="min-width:130px;" /></label>
                  <label style="margin:0;">Date<input type="date" name="date" value="<%= today %>" required /></label>
                  <label style="margin:0;">Method<input type="text" name="method" placeholder="Check, ACH, Card…" style="min-width:130px;" /></label>
                  <label style="margin:0;">Note<input type="text" name="note" placeholder="optional" /></label>
                  <button class="btn btn-primary btn-small" type="submit" style="height:40px;">Save Payment</button>
                  <button class="btn btn-ghost btn-small" type="button" style="height:40px;" onclick="togglePay(<%= o.id %>)">Cancel</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

    <!-- Summary Cards -->
    <% if (summary) { %>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(155px, 1fr)); gap: .8rem; margin-bottom: 1.5rem;">
      <div class="card" style="text-align: center; border-top: 3px solid #e67e22;">
        <p class="muted small" style="margin-bottom: .2rem;">Monthly Recurring</p>
        <p style="font-size: 1.4rem; font-weight: 700; color: #e67e22;">$<%= summary.monthlyTotal.toFixed(2) %></p>
      </div>
      <div class="card" style="text-align: center; border-top: 3px solid #3498db;">
        <p class="muted small" style="margin-bottom: .2rem;">Yearly Recurring</p>
        <p style="font-size: 1.4rem; font-weight: 700; color: #3498db;">$<%= summary.yearlyTotal.toFixed(2) %></p>
      </div>
      <div class="card" style="text-align: center; border-top: 3px solid #9b59b6;">
        <p class="muted small" style="margin-bottom: .2rem;">Startup Costs</p>
        <p style="font-size: 1.4rem; font-weight: 700; color: #9b59b6;">$<%= summary.startupTotal.toFixed(2) %></p>
      </div>
      <div class="card" style="text-align: center; border-top: 3px solid #27ae60;">
        <p class="muted small" style="margin-bottom: .2rem;">Est. Monthly Total</p>
        <p style="font-size: 1.4rem; font-weight: 700; color: #27ae60;">$<%= summary.estimatedMonthly.toFixed(2) %></p>
        <p class="muted small">(monthly + yearly/12)</p>
      </div>
      <% if (summary.dueTotal > 0 || summary.reimburseTotal > 0) { %>
      <div class="card" style="text-align: center; border-top: 3px solid #e74c3c;">
        <p class="muted small" style="margin-bottom: .2rem;">Outstanding</p>
        <p style="font-size: 1.4rem; font-weight: 700; color: #e74c3c;">$<%= (summary.dueTotal + summary.reimburseTotal).toFixed(2) %></p>
        <p class="muted small">
          <% if (summary.dueTotal > 0) { %>$<%= summary.dueTotal.toFixed(2) %> due<% } %>
          <% if (summary.dueTotal > 0 && summary.reimburseTotal > 0) { %> · <% } %>
          <% if (summary.reimburseTotal > 0) { %>$<%= summary.reimburseTotal.toFixed(2) %> owed back<% } %>
        </p>
      </div>
      <% } %>
    </div>

    <% if (summary && summary.owedByPerson && summary.owedByPerson.length > 0) { %>
    <div class="card" style="margin-bottom: 1.5rem; border-left: 4px solid #e74c3c;">
      <h2 style="font-size: 1rem; margin-bottom: .5rem;">Who's Owed Money</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
        <% summary.owedByPerson.forEach(function(p) { %>
        <div style="background: #fff8f0; border: 1px solid #f5cba7; border-radius: 10px; padding: .6rem 1rem; min-width: 160px;">
          <strong style="color: #333;"><%= p.person %></strong>
          <span style="display: block; font-size: 1.2rem; font-weight: 700; color: #e74c3c;">$<%= p.total.toFixed(2) %></span>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% } %>

    <!-- Filters -->
    <div class="card" style="margin-bottom: 1.5rem;">
      <div style="display: flex; flex-wrap: wrap; gap: .8rem; align-items: flex-end;">
        <form class="form" method="GET" action="/admin/expenses" style="display: flex; flex-wrap: wrap; gap: .8rem; align-items: flex-end; margin: 0;">
          <label style="margin: 0;">
            <% if (filter === "monthly" || filter === "yearly" || filter === "recurring" || filter === "startup") { %>
              Year (for recurring/startup)
            <% } else { %>
              Month
            <% } %>
            <input type="<%= (filter === 'monthly' || filter === 'yearly' || filter === 'recurring' || filter === 'startup') ? 'number' : 'month' %>" name="month" value="<%= month %>" style="min-width: 160px;" placeholder="<%= (filter === 'monthly' || filter === 'yearly' || filter === 'recurring' || filter === 'startup') ? '2026' : '' %>" />
          </label>
          <label style="margin: 0;">
            Filter
            <select name="filter" style="min-width: 160px;">
              <option value="" <%= filter === '' ? 'selected' : '' %>>All Expenses (by month)</option>
              <option value="monthly" <%= filter === 'monthly' ? 'selected' : '' %>>Monthly Recurring (all)</option>
              <option value="yearly" <%= filter === 'yearly' ? 'selected' : '' %>>Yearly Recurring (all)</option>
              <option value="recurring" <%= filter === 'recurring' ? 'selected' : '' %>>All Recurring (all)</option>
              <option value="startup" <%= filter === 'startup' ? 'selected' : '' %>>Startup Costs (all)</option>
              <option value="due" <%= filter === 'due' ? 'selected' : '' %>>Bills Due (all)</option>
              <option value="reimburse" <%= filter === 'reimburse' ? 'selected' : '' %>>Needs Reimbursement (all)</option>
              <option value="unpaid" <%= filter === 'unpaid' ? 'selected' : '' %>>All Unpaid (all)</option>
            </select>
          </label>
          <button class="btn btn-primary btn-small" type="submit" style="height: 40px;">Filter</button>
        </form>
      </div>
    </div>
    
    <!-- Quarterly Tax Estimator -->
    <div class="card" style="margin-bottom: 1.5rem; border-left: 4px solid #e67e22;">
      <h2 style="font-size: 1rem; margin-bottom: .5rem;">📊 Quarterly Estimated Tax (Q1-Q4)</h2>
      <p class="muted small" style="margin-bottom: .8rem;">Track quarterly tax payments based on deductible expenses. Rough estimate: 25% of deductible expenses.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem;">
        <% const currentYear = new Date().getFullYear(); %>
        <% for (let q = 1; q <= 4; q++) { %>
        <div style="background: #fff8f0; border: 1px solid #f5cba7; border-radius: 10px; padding: .8rem; cursor: pointer;" onclick="loadQuarterlyTax(<%= currentYear %>, <%= q %>)">
          <p style="font-weight: 600; margin: 0 0 .3rem; font-size: .9rem;">Q<%= q %> <%= currentYear %></p>
          <p class="muted small" style="margin: 0;">Click to view</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- TAX DEDUCTIBLE SUMMARY -->
    <% if (taxSummary) { %>
    <div class="card" style="margin-bottom: 1.5rem; border-left: 4px solid #27ae60;">
      <h2 style="font-size: 1rem; margin-bottom: .5rem;">📋 Tax Deductible Summary — <%= month %></h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <div style="background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 10px; padding: 1rem;">
          <p class="muted small" style="margin-bottom: .3rem;">Total Deductible</p>
          <p style="font-size: 1.3rem; font-weight: 700; color: #27ae60;">$<%= taxSummary.totalDeductible.toFixed(2) %></p>
        </div>
        <div style="background: #fef0f0; border: 1px solid #f5c6cb; border-radius: 10px; padding: 1rem;">
          <p class="muted small" style="margin-bottom: .3rem;">Non-Deductible</p>
          <p style="font-size: 1.3rem; font-weight: 700; color: #e74c3c;">$<%= taxSummary.totalNonDeductible.toFixed(2) %></p>
        </div>
      </div>
      <% if (taxSummary.byCategory.length > 0) { %>
      <h3 style="font-size: .9rem; margin-top: 1rem; margin-bottom: .5rem;">By Category</h3>
      <ul style="margin: 0; padding-left: 1.5rem; font-size: .9rem;">
        <% taxSummary.byCategory.forEach(function(cat) { %>
        <li><strong><%= cat.category %></strong> — $<%= cat.total.toFixed(2) %></li>
        <% }); %>
      </ul>
      <% } %>
    </div>
    <% } %>

    <!-- Add Expense -->
    <div class="card" style="margin-bottom: 1.5rem;">
      <h2>Add / Edit Expense</h2>
      <form class="form" method="POST" action="/admin/expenses" enctype="multipart/form-data">
        <label>
          Description
          <input type="text" name="description" placeholder="What was the expense?" required />
        </label>
        <div class="grid two">
          <label>
            Amount ($)
            <input type="number" name="amount" placeholder="0.00" min="0" step="0.01" required />
          </label>
          <label>
            Date
            <input type="date" name="date" value="<%= new Date().toISOString().slice(0,10) %>" required />
          </label>
        </div>
        <div class="grid two">
          <label>
            Category
            <select name="category" required>
              <option value="Rent">Rent</option>
              <option value="Utilities">Utilities</option>
              <option value="Supplies">Supplies</option>
              <option value="Linens">Linens</option>
              <option value="Insurance">Insurance</option>
              <option value="Marketing">Marketing</option>
              <option value="Payroll">Payroll</option>
              <option value="Equipment">Equipment</option>
              <option value="Maintenance">Maintenance</option>
              <option value="Software">Software</option>
              <option value="Licensing">Licensing</option>
              <option value="Furniture">Furniture</option>
              <option value="Build-Out">Build-Out</option>
              <option value="Signage">Signage</option>
              <option value="General" selected>General</option>
            </select>
          </label>
          <label>
            Frequency
            <select name="frequency">
              <option value="one-time">One-Time</option>
              <option value="monthly">Monthly Recurring</option>
              <option value="yearly">Yearly Recurring</option>
            </select>
          </label>
        </div>
        <div class="grid two">
          <label>
            Payment Status
            <select name="payment_status" id="payment-status-select">
              <option value="paid">Paid — All settled</option>
              <option value="due">Due — Bill not paid yet</option>
              <option value="reimburse">Owe Someone Back — They paid out of pocket</option>
            </select>
          </label>
          <label>
            Vendor / Where <span class="muted small">(where was it purchased?)</span>
            <input type="text" name="vendor" placeholder="e.g., Home Depot, Costco, Amazon" />
          </label>
        </div>
        <div id="reimbursement-fields" style="display: none; background: #fff8f0; border: 1px solid #f5cba7; border-radius: 10px; padding: 1rem; margin-bottom: .5rem;">
          <p style="font-weight: 600; font-size: .85rem; color: #e67e22; margin-bottom: .5rem;">Who needs to be paid back?</p>
          <div class="grid two">
            <label>
              Paid By <span class="muted small">(who spent the money?)</span>
              <input type="text" name="paid_by" placeholder="e.g., Nick, Maria, John" />
            </label>
            <label>
              Owe To <span class="muted small">(who gets reimbursed?)</span>
              <input type="text" name="due_to" placeholder="Same person, or someone else" />
            </label>
          </div>
        </div>
        <div id="due-fields" style="display: none; background: #fef0f0; border: 1px solid #f5c6cb; border-radius: 10px; padding: 1rem; margin-bottom: .5rem;">
          <p style="font-weight: 600; font-size: .85rem; color: #e74c3c; margin-bottom: .5rem;">Who is this owed to?</p>
          <div class="grid two">
            <label>
              Due To <span class="muted small">(company or person)</span>
              <input type="text" name="due_to_bill" placeholder="e.g., Xcel Energy, Landlord" />
            </label>
            <label>
              Due Date <span class="muted small">(optional)</span>
              <input type="date" name="due_date" />
            </label>
          </div>
        </div>
        <div class="grid two">
          <label style="display: flex; align-items: center; gap: .5rem; padding-top: .3rem;">
            <input type="checkbox" name="is_startup" value="1" style="width: 20px; height: 20px;" />
            <span>Startup Cost</span>
          </label>
          <label style="display: flex; align-items: center; gap: .5rem; padding-top: .3rem;">
            <input type="checkbox" name="tax_deductible" value="1" checked style="width: 20px; height: 20px;" />
            <span>Tax Deductible 🧾</span>
          </label>
        </div>
        <label style="display: flex; align-items: center; gap: .5rem; padding-top: .3rem;">
          <input type="checkbox" name="auto_pay" value="1" style="width: 20px; height: 20px;" />
          <span>Auto-Pay 🔄 <span class="muted small">(drafts automatically from the business account)</span></span>
        </label>
        <label>
          Notes <span class="muted small">(optional)</span>
          <input type="text" name="notes" placeholder="Extra details, receipt #, etc." />
        </label>
        <label>
          Receipt <span class="muted small">(optional — photo or PDF)</span>
          <input type="file" name="receipt" accept=".jpg,.jpeg,.png,.gif,.pdf" />
          <span class="muted small" style="display: block; margin-top: .3rem;">Accepted: JPG, PNG, GIF, PDF (max 15MB)</span>
        </label>
        <button class="btn btn-primary" type="submit">Add Expense</button>
      </form>
    </div>

    <!-- Totals by Category -->
    <% if (totals.length > 0) { %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <h2>Totals for <%= month %><%= filter ? ' (' + filter + ')' : '' %></h2>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr><th>Category</th><th>Total</th></tr>
          </thead>
          <tbody>
            <% totals.forEach(function(t) { %>
            <tr>
              <td><%= t.category %></td>
              <td><strong>$<%= t.total.toFixed(2) %></strong></td>
            </tr>
            <% }); %>
          </tbody>
          <tfoot>
            <tr>
              <td><strong>Grand Total</strong></td>
              <td><strong>$<%= grandTotal.toFixed(2) %></strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
    <% } %>

    <!-- Expense List -->
    <h2>Expenses — <%= month %><%= filter ? ' (' + filter + ')' : '' %></h2>
    <% if (expenses.length === 0) { %>
    <div class="card"><p class="muted">No expenses match your filters.</p></div>
    <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Category</th>
            <th>Vendor</th>
            <th>Frequency</th>
            <th>Status</th>
            <th>Amount</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% expenses.forEach(function(e) { %>
          <tr style="<%= e.payment_status === 'due' || e.payment_status === 'reimburse' ? 'background: #fff8f0;' : '' %>"
              data-id="<%= e.id %>"
              data-description="<%= e.description %>"
              data-amount="<%= e.amount %>"
              data-date="<%= e.date %>"
              data-category="<%= e.category %>"
              data-vendor="<%= e.vendor || '' %>"
              data-frequency="<%= e.frequency || 'one-time' %>"
              data-status="<%= e.payment_status || 'paid' %>"
              data-startup="<%= e.is_startup ? 1 : 0 %>"
              data-tax="<%= e.tax_deductible ? 1 : 0 %>"
              data-autopay="<%= e.auto_pay ? 1 : 0 %>"
              data-notes="<%= e.notes || '' %>"
              data-dueto="<%= e.due_to || '' %>"
              data-duedate="<%= e.due_date || '' %>"
              data-paidby="<%= e.paid_by || '' %>">
            <td><%= e.date %></td>
            <td>
              <%= e.description %>
              <% if (e.is_startup) { %>
                <span style="display: inline-block; font-size: .7rem; background: #9b59b6; color: #fff; padding: .1rem .4rem; border-radius: 4px; margin-left: .3rem;">STARTUP</span>
              <% } %>
              <% if (e.tax_deductible) { %>
                <span style="display: inline-block; font-size: .7rem; background: #27ae60; color: #fff; padding: .1rem .4rem; border-radius: 4px; margin-left: .3rem;">TAX✓</span>
              <% } %>
              <% if (e.auto_pay) { %>
                <span style="display: inline-block; font-size: .7rem; background: #16a085; color: #fff; padding: .1rem .4rem; border-radius: 4px; margin-left: .3rem;">🔄 AUTO-PAY</span>
              <% } %>
              <% if (e.receipt_file) { %>
                <br /><a href="<%= e.receipt_file %>" target="_blank" style="display: inline-block; font-size: .75rem; background: #3498db; color: #fff; padding: .15rem .5rem; border-radius: 4px; text-decoration: none; margin-top: .3rem;">📎 View Receipt</a>
              <% } %>
              <% if (e.due_to) { %>
                <br /><span style="font-size: .8rem; color: #e74c3c; font-weight: 600;">Owe: <%= e.due_to %></span>
              <% } %>
              <% if (e.paid_by) { %>
                <br /><span class="muted small">Paid by: <strong><%= e.paid_by %></strong></span>
              <% } %>
              <% if (e.due_date) { %>
                <br /><span class="muted small">Due by: <%= e.due_date %></span>
              <% } %>
              <% if (e.notes) { %>
                <br /><span class="muted small"><%= e.notes %></span>
              <% } %>
            </td>
            <td><%= e.category %></td>
            <td class="muted"><%= e.vendor || '—' %></td>
            <td>
              <% if (e.frequency === 'monthly') { %>
                <span style="display: inline-block; font-size: .75rem; background: #e67e22; color: #fff; padding: .15rem .5rem; border-radius: 4px;">Monthly</span>
              <% } else if (e.frequency === 'yearly') { %>
                <span style="display: inline-block; font-size: .75rem; background: #3498db; color: #fff; padding: .15rem .5rem; border-radius: 4px;">Yearly</span>
              <% } else { %>
                <span class="muted small">One-time</span>
              <% } %>
            </td>
            <td>
              <% if (e.payment_status === 'due') { %>
                <span style="display: inline-block; font-size: .75rem; background: #e74c3c; color: #fff; padding: .15rem .5rem; border-radius: 4px;">Due</span>
              <% } else if (e.payment_status === 'reimburse') { %>
                <span style="display: inline-block; font-size: .75rem; background: #e67e22; color: #fff; padding: .15rem .5rem; border-radius: 4px;">Owed Back</span>
              <% } else { %>
                <span style="display: inline-block; font-size: .75rem; background: #27ae60; color: #fff; padding: .15rem .5rem; border-radius: 4px;">Paid</span>
                <% if (e.paid_date) { %><br /><span class="muted small"><%= e.paid_date %></span><% } %>
              <% } %>
            </td>
            <td style="white-space: nowrap;">
              <strong>$<%= money(e.amount) %></strong>
              <% if ((e.payment_status === 'due' || e.payment_status === 'reimburse') && e.paid_to_date > 0) { %>
                <br /><span class="muted small">Paid $<%= money(e.paid_to_date) %></span>
                <br /><span style="font-size: .8rem; color: #e74c3c; font-weight: 600;">$<%= money(e.amount - e.paid_to_date) %> left</span>
              <% } %>
            </td>
            <td style="white-space: nowrap;">
              <button class="btn btn-small" type="button" style="background: #3498db; color: #fff; margin-bottom: .3rem;" onclick="editExpense(<%= e.id %>)">Edit</button>
              <% if (e.payment_status === 'due' || e.payment_status === 'reimburse') { %>
              <button class="btn btn-small btn-primary" type="button" style="margin-bottom: .3rem;" onclick="togglePay(<%= e.id %>)">＋ Payment</button>
              <form method="POST" action="/admin/expenses/<%= e.id %>/mark-paid" style="display: inline;">
                <button class="btn btn-small" type="submit" style="background: #27ae60; color: #fff; margin-bottom: .3rem;">Mark Paid</button>
              </form>
              <% } %>
              <form method="POST" action="/admin/expenses/<%= e.id %>/delete" style="display: inline;" onsubmit="return confirm('Delete this expense?')">
                <button class="btn btn-small btn-ghost" type="submit" style="color: #c0392b;">Delete</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</main>

<script>
// Show/hide reimbursement or due fields based on payment status
(function(){
  var sel = document.getElementById('payment-status-select');
  var reimFields = document.getElementById('reimbursement-fields');
  var dueFields = document.getElementById('due-fields');
  if (!sel) return;
  function toggle() {
    reimFields.style.display = sel.value === 'reimburse' ? 'block' : 'none';
    dueFields.style.display = sel.value === 'due' ? 'block' : 'none';
  }
  sel.addEventListener('change', toggle);
  toggle();
})();

// Load quarterly tax data via AJAX
function loadQuarterlyTax(year, quarter) {
  fetch('/api/admin/quarterly-tax?year=' + year + '&quarter=' + quarter)
    .then(r => r.json())
    .then(data => {
      if (!data.quarterly) { alert('No data'); return; }
      const q = data.quarterly;
      let msg = 'Q' + q.quarter + ' ' + q.year + '\n\n';
      msg += 'Total Deductible: $' + q.totalDeductible.toFixed(2) + '\n';
      msg += 'Est. Tax Owed (~25%): $' + q.estimatedTaxOwed.toFixed(2) + '\n\n';
      if (q.byCategory.length > 0) {
        msg += 'By Category:\n';
        q.byCategory.forEach(cat => {
          msg += '  ' + cat.category + ': $' + cat.total.toFixed(2) + '\n';
        });
      }
      alert(msg);
    })
    .catch(e => alert('Error loading quarterly data'));
}

// Show/hide the inline "record payment" form for an expense
function togglePay(id) {
  var row = document.getElementById('pay-' + id);
  if (!row) return;
  var showing = row.style.display !== 'none';
  row.style.display = showing ? 'none' : 'table-row';
  if (!showing) {
    row.scrollIntoView({ behavior: 'smooth', block: 'center' });
    var amt = row.querySelector('input[name="amount"]');
    if (amt) amt.focus();
  }
}

// Edit expense — populate ALL fields from the row's data attributes (so editing
// never silently resets status, frequency, auto-pay, notes, etc.)
function editExpense(id) {
  const row = document.querySelector('tr[data-id="' + id + '"]');
  const form = document.querySelector('form[action^="/admin/expenses"]');
  if (!row || !form) return;
  const d = row.dataset;

  form.action = '/admin/expenses/' + id + '/edit';
  form.style.background = '#e8f5e9';
  form.style.border = '2px solid #27ae60';
  form.style.padding = '1rem';
  form.style.borderRadius = '10px';

  form.description.value = d.description || '';
  form.amount.value = d.amount || '';
  form.date.value = d.date || '';
  form.category.value = d.category || 'General';
  form.vendor.value = d.vendor || '';
  form.frequency.value = d.frequency || 'one-time';
  form.notes.value = d.notes || '';
  form.is_startup.checked = d.startup === '1';
  form.tax_deductible.checked = d.tax === '1';
  form.auto_pay.checked = d.autopay === '1';

  // Payment status + its dependent fields
  const sel = document.getElementById('payment-status-select');
  sel.value = d.status || 'paid';
  sel.dispatchEvent(new Event('change'));
  if (d.status === 'due') {
    if (form.due_to_bill) form.due_to_bill.value = d.dueto || '';
    if (form.due_date) form.due_date.value = d.duedate || '';
  } else if (d.status === 'reimburse') {
    if (form.due_to) form.due_to.value = d.dueto || '';
    if (form.paid_by) form.paid_by.value = d.paidby || '';
  }

  form.scrollIntoView({ behavior: 'smooth', block: 'start' });

  const btn = form.querySelector('button[type="submit"]');
  if (btn) { btn.textContent = 'Update Expense'; btn.style.background = '#27ae60'; }

  if (!form.querySelector('.cancel-edit')) {
    const cancelBtn = document.createElement('button');
    cancelBtn.type = 'button';
    cancelBtn.className = 'btn btn-ghost cancel-edit';
    cancelBtn.textContent = 'Cancel';
    cancelBtn.style.marginLeft = '.5rem';
    cancelBtn.onclick = function() {
      form.action = '/admin/expenses';
      form.reset();
      form.style.background = '';
      form.style.border = '';
      form.style.padding = '';
      btn.textContent = 'Add Expense';
      btn.style.background = '';
      document.getElementById('payment-status-select').dispatchEvent(new Event('change'));
      this.remove();
    };
    btn.parentNode.insertBefore(cancelBtn, btn.nextSibling);
  }
}
</script>

</body>
</html>
