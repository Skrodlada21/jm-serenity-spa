<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Welcome — J&M Serenity Spa</title>
  <link rel="icon" type="image/png" href="/images/favicon-32.png" sizes="32x32" />
  <style>
    :root { --brand:#1f6f78; --brand-deep:#114a50; --gold:#c9a96e; --cream:#faf7f2; --text:#2c2c2c; }
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
    html, body { height: 100%; }
    body { font-family: -apple-system, "Segoe UI", Roboto, sans-serif; background: var(--cream); color: var(--text);
      display: flex; align-items: center; justify-content: center; padding: 3vh 4vw; overflow: hidden; user-select: none; }
    .kiosk { width: 100%; max-width: 720px; text-align: center; }
    .logo { width: 84px; height: 84px; border-radius: 50%; object-fit: cover; border: 3px solid var(--gold); margin-bottom: 1rem; }
    h1 { font-size: 2rem; color: var(--brand-deep); }
    .sub { color: #888; font-size: 1.1rem; margin-top: .3rem; margin-bottom: 2rem; }
    .screen { display: none; }
    .screen.active { display: block; animation: fade .25s ease; }
    @keyframes fade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .big-btn { display: block; width: 100%; padding: 1.5rem; font-size: 1.5rem; font-weight: 700; border: none;
      border-radius: 18px; cursor: pointer; margin-bottom: 1rem; }
    .big-btn.primary { background: var(--brand); color: #fff; }
    .big-btn.gold { background: var(--gold); color: #3a2c14; }
    .big-btn.ghost { background: #fff; color: var(--brand); border: 2px solid var(--brand); }
    .field { margin-bottom: 1rem; text-align: left; }
    .field label { display: block; font-weight: 600; margin-bottom: .4rem; font-size: 1.05rem; }
    .field input { width: 100%; padding: 1rem; font-size: 1.5rem; border: 2px solid #ddd; border-radius: 14px; }
    .phone-display { font-size: 2.2rem; font-weight: 700; letter-spacing: 2px; min-height: 3rem; color: var(--brand-deep);
      background: #fff; border: 2px solid #e5ded3; border-radius: 14px; padding: .6rem; margin-bottom: 1rem; }
    .keypad { display: grid; grid-template-columns: repeat(3, 1fr); gap: .7rem; margin-bottom: 1.2rem; }
    .keypad button { padding: 1.1rem; font-size: 1.8rem; font-weight: 700; border: none; border-radius: 14px;
      background: #fff; border: 1px solid #e5ded3; cursor: pointer; }
    .keypad button:active { background: #eee; }
    .appt-card { background: #fff; border: 2px solid var(--brand); border-radius: 16px; padding: 1.1rem; margin-bottom: 1rem; text-align: left; }
    .appt-card .t { font-size: 1.6rem; font-weight: 800; color: var(--brand-deep); }
    .appt-card .s { font-size: 1.15rem; color: #555; margin: .2rem 0 .8rem; }
    .services { display: grid; grid-template-columns: repeat(2, 1fr); gap: .7rem; margin-bottom: 1rem; }
    .service-tile { padding: 1rem; font-size: 1.05rem; font-weight: 600; border: 2px solid #ddd; border-radius: 14px; background: #fff; cursor: pointer; }
    .service-tile.sel { border-color: var(--brand); background: #e9f2f2; color: var(--brand-deep); }
    .done-check { font-size: 5rem; }
    .msg { color: #c0392b; font-weight: 600; margin-bottom: 1rem; min-height: 1.4rem; }
    .back { margin-top: .5rem; background: transparent; border: none; color: #999; font-size: 1rem; cursor: pointer; text-decoration: underline; }
  </style>
</head>
<body>
  <div class="kiosk">
    <img class="logo" src="/images/logo.png" alt="J&M Serenity Spa" />

    <!-- HOME -->
    <div class="screen active" id="screen-home">
      <h1>Welcome!</h1>
      <p class="sub">Please check in below.</p>
      <button class="big-btn primary" onclick="show('appt')">📅 &nbsp;I have an appointment</button>
      <button class="big-btn gold" onclick="show('walkin')">🚶 &nbsp;I'm a walk-in</button>
    </div>

    <!-- APPOINTMENT -->
    <div class="screen" id="screen-appt">
      <h1>Your phone number</h1>
      <p class="sub">We'll find your appointment.</p>
      <div class="phone-display" id="phoneDisp"></div>
      <div class="keypad">
        <% [1,2,3,4,5,6,7,8,9].forEach(function(n){ %><button onclick="key('<%= n %>')"><%= n %></button><% }); %>
        <button onclick="key('back')">⌫</button>
        <button onclick="key('0')">0</button>
        <button onclick="key('clear')">✕</button>
      </div>
      <div class="msg" id="apptMsg"></div>
      <div id="apptResults"></div>
      <button class="big-btn primary" id="findBtn" onclick="findAppt()">Find my appointment</button>
      <button class="back" onclick="show('home')">← Back</button>
    </div>

    <!-- WALK-IN -->
    <div class="screen" id="screen-walkin">
      <h1>Walk-in check-in</h1>
      <p class="sub">Enter your info and what you'd like.</p>
      <div class="field"><label>Your name</label><input type="text" id="wName" autocomplete="off" /></div>
      <div class="field"><label>Phone number</label><input type="tel" id="wPhone" autocomplete="off" /></div>
      <div class="field"><label>What would you like?</label>
        <div class="services" id="svcTiles">
          <% services.forEach(function(s){ %>
          <div class="service-tile" data-id="<%= s.id %>" onclick="pickSvc(this)"><%= s.name %></div>
          <% }); %>
        </div>
      </div>
      <div class="msg" id="walkMsg"></div>
      <button class="big-btn gold" onclick="submitWalkin()">Check in</button>
      <button class="back" onclick="show('home')">← Back</button>
    </div>

    <!-- DONE -->
    <div class="screen" id="screen-done">
      <div class="done-check">✅</div>
      <h1 id="doneTitle">You're all set!</h1>
      <p class="sub" id="doneMsg">Please have a seat — we'll be right with you.</p>
    </div>
  </div>

  <script>
    var phone = "", selSvc = "";
    function show(name) {
      document.querySelectorAll(".screen").forEach(function (s) { s.classList.remove("active"); });
      document.getElementById("screen-" + name).classList.add("active");
      if (name === "appt") { phone = ""; render(); document.getElementById("apptResults").innerHTML = ""; document.getElementById("apptMsg").textContent = ""; document.getElementById("findBtn").style.display = ""; }
      if (name === "walkin") { document.getElementById("wName").value = ""; document.getElementById("wPhone").value = ""; selSvc = ""; document.querySelectorAll(".service-tile").forEach(function(t){t.classList.remove("sel");}); document.getElementById("walkMsg").textContent = ""; }
    }
    function render() { document.getElementById("phoneDisp").textContent = phone.replace(/(\d{3})(\d{3})(\d{0,4})/, "$1-$2-$3").replace(/-+$/,""); }
    function key(k) {
      if (k === "back") phone = phone.slice(0, -1);
      else if (k === "clear") phone = "";
      else if (phone.length < 10) phone += k;
      render();
    }
    function findAppt() {
      var msg = document.getElementById("apptMsg"), out = document.getElementById("apptResults");
      out.innerHTML = ""; msg.textContent = "";
      if (phone.replace(/\D/g, "").length < 7) { msg.textContent = "Please enter your phone number."; return; }
      fetch("/api/arrive/lookup", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ phone: phone }) })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.bookings || !d.bookings.length) {
            msg.textContent = "No appointment found for today. If you're a walk-in, tap Back and choose Walk-in.";
            return;
          }
          document.getElementById("findBtn").style.display = "none";
          d.bookings.forEach(function (b) {
            var div = document.createElement("div");
            div.className = "appt-card";
            div.innerHTML = '<div class="t">' + b.time + '</div><div class="s">' + (b.service || "") + (b.therapist ? " · " + b.therapist : "") + '</div>';
            var btn = document.createElement("button");
            btn.className = "big-btn primary";
            btn.style.margin = "0";
            btn.textContent = b.arrived ? "✓ Already checked in" : "I'm here ✓";
            btn.disabled = b.arrived;
            btn.onclick = function () { checkin(b.id, b.name); };
            div.appendChild(btn);
            out.appendChild(div);
          });
        }).catch(function () { msg.textContent = "Something went wrong. Please see the front desk."; });
    }
    function checkin(id, name) {
      fetch("/api/arrive/checkin", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ booking_id: id }) })
        .then(function (r) { return r.json(); })
        .then(function () { done("You're checked in!" , (name ? "Thanks, " + name.split(" ")[0] + "! " : "") + "Please have a seat — your therapist will be with you shortly."); })
        .catch(function () { done("You're checked in!", "Please have a seat."); });
    }
    function pickSvc(el) { document.querySelectorAll(".service-tile").forEach(function(t){t.classList.remove("sel");}); el.classList.add("sel"); selSvc = el.getAttribute("data-id"); }
    function submitWalkin() {
      var name = document.getElementById("wName").value.trim();
      var ph = document.getElementById("wPhone").value.trim();
      var msg = document.getElementById("walkMsg");
      if (!name || !ph) { msg.textContent = "Please enter your name and phone number."; return; }
      fetch("/api/arrive/walkin", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ name: name, phone: ph, service_id: selSvc }) })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.ok) done("Thank you, " + name.split(" ")[0] + "!", "You're on the list. Please have a seat — we'll be right with you.");
          else msg.textContent = d.error || "Something went wrong.";
        }).catch(function () { msg.textContent = "Something went wrong. Please see the front desk."; });
    }
    function done(title, m) {
      document.getElementById("doneTitle").textContent = title;
      document.getElementById("doneMsg").textContent = m;
      show("done");
      setTimeout(function () { show("home"); }, 7000);
    }
    // Reset to home after 60s of inactivity so it's ready for the next guest
    var idle; ["click","touchstart","keydown"].forEach(function(e){ document.addEventListener(e, function(){ clearTimeout(idle); idle = setTimeout(function(){ show("home"); }, 60000); }); });
  </script>
</body>
</html>
