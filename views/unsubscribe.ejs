<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Unsubscribe — <%= spaName %></title>
  <link rel="icon" type="image/png" href="/images/favicon-32.png" sizes="32x32" />
  <style>
    body { font-family: 'Inter', -apple-system, sans-serif; background: #faf7f2; color: #2c2c2c; margin: 0; display: flex; min-height: 100vh; align-items: center; justify-content: center; }
    .box { background: #fff; max-width: 460px; margin: 1.5rem; padding: 2.5rem 2rem; border-radius: 16px; box-shadow: 0 8px 40px rgba(0,0,0,.08); text-align: center; }
    h1 { color: #1f6f78; font-size: 1.5rem; margin: 0 0 .5rem; }
    p { line-height: 1.6; color: #555; }
    .email { font-weight: 600; color: #333; }
    a { color: #1f6f78; }
  </style>
</head>
<body>
  <div class="box">
    <% if (found) { %>
      <h1>You're unsubscribed</h1>
      <p><span class="email"><%= email %></span> has been removed from <%= spaName %> update emails. You won't receive any more.</p>
      <p style="font-size:.9rem; color:#888;">Changed your mind? You can sign up again anytime on our website.</p>
    <% } else { %>
      <h1>Link not recognized</h1>
      <p>This unsubscribe link isn't valid or has already been used. If you're still getting emails, reply to one and we'll remove you right away.</p>
    <% } %>
  </div>
</body>
</html>
